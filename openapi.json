{
  "openapi": "3.0.0",
  "info": {
    "title": "Agent Orcha API",
    "version": "1.0.0",
    "description": "API for orchestrating agents, workflows, knowledge stores, functions, MCP servers, LLMs, and local model management."
  },
  "servers": [
    {
      "url": "http://localhost:3333",
      "description": "Local Development Server"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health Check",
        "tags": ["Infrastructure"],
        "responses": {
          "200": {
            "description": "Server is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "ok" },
                    "version": { "type": "string" },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/check": {
      "get": {
        "summary": "Check Auth Status",
        "tags": ["Auth"],
        "responses": {
          "200": {
            "description": "Auth status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "authenticated": { "type": "boolean" },
                    "required": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "password": { "type": "string" }
                },
                "required": ["password"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Authenticated (sets session cookie)" },
          "401": { "description": "Invalid password" },
          "429": { "description": "Rate limit exceeded" }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "summary": "Logout",
        "tags": ["Auth"],
        "responses": {
          "200": { "description": "Session cleared" }
        }
      }
    },
    "/api/agents": {
      "get": {
        "summary": "List Agents",
        "tags": ["Agents"],
        "responses": {
          "200": {
            "description": "List of available agents",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": { "type": "string" },
                      "description": { "type": "string" },
                      "version": { "type": "string" },
                      "tools": { "type": "array", "items": { "type": "string" } },
                      "memory": {},
                      "inputVariables": { "type": "array", "items": { "type": "string" } },
                      "publish": { "type": "object" },
                      "sampleQuestions": { "type": "array", "items": { "type": "string" } }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/agents/{name}": {
      "get": {
        "summary": "Get Agent Details",
        "tags": ["Agents"],
        "parameters": [{ "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Agent details" },
          "404": { "description": "Agent not found" }
        }
      }
    },
    "/api/agents/{name}/invoke": {
      "post": {
        "summary": "Invoke Agent",
        "tags": ["Agents"],
        "parameters": [{ "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "input": { "type": "object" },
                  "sessionId": { "type": "string" }
                },
                "required": ["input"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "output": {},
                    "metadata": {
                      "type": "object",
                      "properties": {
                        "tokensUsed": { "type": "integer" },
                        "toolCalls": { "type": "array" },
                        "duration": { "type": "integer" },
                        "sessionId": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": { "description": "Agent not found" }
        }
      }
    },
    "/api/agents/{name}/stream": {
      "post": {
        "summary": "Stream Agent Execution (SSE)",
        "tags": ["Agents"],
        "parameters": [{ "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "input": { "type": "object" },
                  "sessionId": { "type": "string" }
                },
                "required": ["input"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "SSE stream: task_id, content, thinking, tool_start, tool_end, error, [DONE]", "content": { "text/event-stream": { "schema": { "type": "string" } } } }
        }
      }
    },
    "/api/agents/sessions/stats": {
      "get": {
        "summary": "Get Session Statistics",
        "tags": ["Agents"],
        "responses": {
          "200": {
            "description": "Session stats",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "totalSessions": { "type": "integer" } } } } }
          }
        }
      }
    },
    "/api/agents/sessions/{sessionId}": {
      "get": {
        "summary": "Get Session Details",
        "tags": ["Agents"],
        "parameters": [{ "name": "sessionId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Session details" },
          "404": { "description": "Session not found" }
        }
      },
      "delete": {
        "summary": "Clear Session",
        "tags": ["Agents"],
        "parameters": [{ "name": "sessionId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Session cleared" }
        }
      }
    },
    "/api/agents/sessions/{sessionId}/messages": {
      "get": {
        "summary": "Get Session Messages",
        "tags": ["Agents"],
        "parameters": [{ "name": "sessionId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Array of messages" },
          "404": { "description": "Session not found" }
        }
      }
    },
    "/api/llm/config": {
      "get": {
        "summary": "Get LLM Config",
        "tags": ["LLM"],
        "responses": {
          "200": {
            "description": "Full llm.json with redacted API keys",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "version": { "type": "string" },
                    "models": { "type": "object" },
                    "embeddings": { "type": "object" },
                    "image": { "type": "object" },
                    "tts": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/llm/config/models/{name}": {
      "put": {
        "summary": "Upsert Model Config",
        "tags": ["LLM"],
        "parameters": [{ "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object" } } } },
        "responses": { "200": { "description": "OK" } }
      },
      "delete": {
        "summary": "Delete Model Config",
        "tags": ["LLM"],
        "parameters": [{ "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Deleted" }, "400": { "description": "Cannot delete default" } }
      }
    },
    "/api/llm/config/models/{name}/active": {
      "patch": {
        "summary": "Toggle Model Active",
        "tags": ["LLM"],
        "parameters": [{ "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "active": { "type": "boolean" } }, "required": ["active"] } } } },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/llm/config/models/{name}/p2p": {
      "patch": {
        "summary": "Toggle Model P2P Sharing",
        "tags": ["LLM"],
        "parameters": [{ "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "p2p": { "type": "boolean" } }, "required": ["p2p"] } } } },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/llm/config/embeddings/{name}": {
      "put": {
        "summary": "Upsert Embedding Config",
        "tags": ["LLM"],
        "parameters": [{ "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object" } } } },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/llm/readiness": {
      "get": {
        "summary": "Check LLM Readiness",
        "tags": ["LLM"],
        "responses": {
          "200": {
            "description": "Readiness status",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "ready": { "type": "boolean" }, "issues": { "type": "array", "items": { "type": "string" } } } } } }
          }
        }
      }
    },
    "/api/llm": {
      "get": {
        "summary": "List Active LLMs",
        "tags": ["LLM"],
        "responses": { "200": { "description": "Array of active LLM configs" } }
      }
    },
    "/api/llm/{name}": {
      "get": {
        "summary": "Get LLM Details",
        "tags": ["LLM"],
        "parameters": [{ "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "LLM config" }, "404": { "description": "Not found" } }
      }
    },
    "/api/llm/{name}/chat": {
      "post": {
        "summary": "Chat with LLM",
        "tags": ["LLM"],
        "parameters": [{ "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string" }, "sessionId": { "type": "string" }, "attachments": { "type": "array" } }, "required": ["message"] } } } },
        "responses": { "200": { "description": "Chat response with output and model name" }, "400": { "description": "Message required" } }
      }
    },
    "/api/llm/{name}/stream": {
      "post": {
        "summary": "Stream Chat with LLM (SSE)",
        "tags": ["LLM"],
        "parameters": [{ "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string" }, "sessionId": { "type": "string" } }, "required": ["message"] } } } },
        "responses": { "200": { "description": "SSE stream: task_id, content, thinking, usage, [DONE]" }, "400": { "description": "Message required" } }
      }
    },
    "/api/local-llm/engines": {
      "get": {
        "summary": "List Local Engines",
        "tags": ["Local LLM"],
        "responses": {
          "200": {
            "description": "Engine availability",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "omni": { "type": "object" }, "ollama": { "type": "object" }, "lmstudio": { "type": "object" } } } } }
          }
        }
      }
    },
    "/api/local-llm/engines/urls": {
      "get": {
        "summary": "Get Engine URLs",
        "tags": ["Local LLM"],
        "responses": { "200": { "description": "Custom engine base URLs" } }
      },
      "post": {
        "summary": "Set Engine URL",
        "tags": ["Local LLM"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "engine": { "type": "string" }, "url": { "type": "string" } }, "required": ["engine", "url"] } } } },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/local-llm/engines/activate": {
      "post": {
        "summary": "Activate External Engine Model",
        "tags": ["Local LLM"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "engine": { "type": "string" }, "model": { "type": "string" }, "role": { "type": "string" } }, "required": ["engine", "model"] } } } },
        "responses": { "200": { "description": "Model activated" } }
      }
    },
    "/api/local-llm/engines/context": {
      "post": {
        "summary": "Update Context Size",
        "tags": ["Local LLM"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "contextSize": { "type": "integer" } }, "required": ["contextSize"] } } } },
        "responses": { "200": { "description": "Context size updated" } }
      }
    },
    "/api/local-llm/engines/unload": {
      "post": {
        "summary": "Unload External Engine Model",
        "tags": ["Local LLM"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "engine": { "type": "string" }, "model": { "type": "string" } }, "required": ["engine", "model"] } } } },
        "responses": { "200": { "description": "Model unloaded" } }
      }
    },
    "/api/local-llm/status": {
      "get": {
        "summary": "Get Local LLM Status",
        "tags": ["Local LLM"],
        "responses": {
          "200": {
            "description": "System and model status",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "omni": { "type": "object" }, "available": { "type": "boolean" }, "lastActiveModel": { "type": "string" }, "systemRamBytes": { "type": "integer" }, "freeRamBytes": { "type": "integer" }, "gpu": { "type": "object" }, "defaultProvider": { "type": "string" }, "platform": { "type": "string" }, "arch": { "type": "string" } } } } }
          }
        }
      }
    },
    "/api/local-llm/models": {
      "get": {
        "summary": "List Downloaded Models",
        "tags": ["Local LLM"],
        "responses": { "200": { "description": "Array of local models with id, fileName, filePath, sizeBytes, repo, downloadedAt" } }
      }
    },
    "/api/local-llm/models/downloads": {
      "get": {
        "summary": "Get Active Downloads",
        "tags": ["Local LLM"],
        "responses": { "200": { "description": "Array of active download progress" } }
      }
    },
    "/api/local-llm/models/interrupted": {
      "get": {
        "summary": "Get Interrupted Downloads",
        "tags": ["Local LLM"],
        "responses": { "200": { "description": "Array of interrupted downloads" } }
      }
    },
    "/api/local-llm/models/interrupted/{fileName}": {
      "delete": {
        "summary": "Delete Interrupted Download",
        "tags": ["Local LLM"],
        "parameters": [{ "name": "fileName", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Deleted" } }
      }
    },
    "/api/local-llm/models/download": {
      "get": {
        "summary": "Download Model (SSE)",
        "tags": ["Local LLM"],
        "parameters": [
          { "name": "repo", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "fileName", "in": "query", "schema": { "type": "string" } },
          { "name": "type", "in": "query", "schema": { "type": "string", "enum": ["gguf", "dir", "bundle"] } },
          { "name": "subdir", "in": "query", "schema": { "type": "string" } },
          { "name": "targetDir", "in": "query", "schema": { "type": "string" } },
          { "name": "files", "in": "query", "schema": { "type": "string" }, "description": "JSON array for bundle downloads" }
        ],
        "responses": { "200": { "description": "SSE stream: progress events, complete event, optional mmproj event" } }
      }
    },
    "/api/local-llm/models/{id}/activate": {
      "post": {
        "summary": "Activate Omni Chat Model",
        "tags": ["Local LLM"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Model loaded" } }
      }
    },
    "/api/local-llm/models/{id}/activate-embedding": {
      "post": {
        "summary": "Activate Omni Embedding Model",
        "tags": ["Local LLM"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Embedding model loaded" } }
      }
    },
    "/api/local-llm/models/{id}": {
      "delete": {
        "summary": "Delete Model",
        "tags": ["Local LLM"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Model deleted" }, "409": { "description": "Model is currently active" } }
      }
    },
    "/api/local-llm/browse": {
      "get": {
        "summary": "Browse HuggingFace Models",
        "tags": ["Local LLM"],
        "parameters": [
          { "name": "q", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Array of HuggingFace model results" } }
      }
    },
    "/api/local-llm/stop": {
      "post": { "summary": "Unload Omni Chat Model", "tags": ["Local LLM"], "responses": { "200": { "description": "Model unloaded" } } }
    },
    "/api/local-llm/stop-embedding": {
      "post": { "summary": "Unload Omni Embedding Model", "tags": ["Local LLM"], "responses": { "200": { "description": "Model unloaded" } } }
    },
    "/api/local-llm/stop-image": {
      "post": { "summary": "Unload Omni Image Model", "tags": ["Local LLM"], "responses": { "200": { "description": "Model unloaded" } } }
    },
    "/api/local-llm/stop-tts": {
      "post": { "summary": "Unload Omni TTS Model", "tags": ["Local LLM"], "responses": { "200": { "description": "Model unloaded" } } }
    },
    "/api/local-llm/start-embedding": {
      "post": { "summary": "Pre-load Omni Embedding Model", "tags": ["Local LLM"], "responses": { "200": { "description": "Model loaded" }, "400": { "description": "No embedding model configured" } } }
    },
    "/api/local-llm/start-image": {
      "post": { "summary": "Pre-load Omni Image Model", "tags": ["Local LLM"], "responses": { "200": { "description": "Model loaded" }, "400": { "description": "No image model configured" } } }
    },
    "/api/local-llm/start-tts": {
      "post": { "summary": "Pre-load Omni TTS Model", "tags": ["Local LLM"], "responses": { "200": { "description": "Model loaded" }, "400": { "description": "No TTS model configured" } } }
    },
    "/api/knowledge": {
      "get": {
        "summary": "List Knowledge Stores",
        "tags": ["Knowledge"],
        "responses": {
          "200": {
            "description": "Array of knowledge stores with status",
            "content": { "application/json": { "schema": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "hasGraph": { "type": "boolean" }, "description": { "type": "string" }, "source": { "type": "string" }, "status": { "type": "string" }, "chunkCount": { "type": "integer" }, "entityCount": { "type": "integer" }, "isIndexing": { "type": "boolean" } } } } } }
          }
        }
      }
    },
    "/api/knowledge/{name}": {
      "get": {
        "summary": "Get Knowledge Store Config",
        "tags": ["Knowledge"],
        "parameters": [{ "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Store config" }, "404": { "description": "Not found" } }
      }
    },
    "/api/knowledge/{name}/status": {
      "get": {
        "summary": "Get Knowledge Store Status",
        "tags": ["Knowledge"],
        "parameters": [{ "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Status with chunk/entity counts, indexing state" } }
      }
    },
    "/api/knowledge/{name}/index": {
      "post": {
        "summary": "Trigger Indexing",
        "tags": ["Knowledge"],
        "parameters": [{ "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Indexing started" }, "409": { "description": "Already indexing" } }
      }
    },
    "/api/knowledge/{name}/index/stream": {
      "get": {
        "summary": "Index Progress Stream (SSE)",
        "tags": ["Knowledge"],
        "parameters": [{ "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "SSE stream of indexing progress" } }
      }
    },
    "/api/knowledge/{name}/search": {
      "post": {
        "summary": "Search Knowledge Store",
        "tags": ["Knowledge"],
        "parameters": [{ "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "query": { "type": "string" }, "k": { "type": "integer", "default": 4 } }, "required": ["query"] } } } },
        "responses": { "200": { "description": "Search results with content, metadata, score" }, "404": { "description": "Not found" } }
      }
    },
    "/api/knowledge/{name}/refresh": {
      "post": {
        "summary": "Refresh Knowledge Store",
        "tags": ["Knowledge"],
        "parameters": [{ "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Refresh triggered" } }
      }
    },
    "/api/knowledge/{name}/add": {
      "post": {
        "summary": "Add Documents",
        "tags": ["Knowledge"],
        "parameters": [{ "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "documents": { "type": "array", "items": { "type": "object", "properties": { "content": { "type": "string" }, "metadata": { "type": "object" } }, "required": ["content"] } } }, "required": ["documents"] } } } },
        "responses": { "200": { "description": "Documents added", "content": { "application/json": { "schema": { "type": "object", "properties": { "success": { "type": "boolean" }, "added": { "type": "integer" } } } } } } }
      }
    },
    "/api/knowledge/{name}/entities": {
      "get": {
        "summary": "Get Graph Entities",
        "tags": ["Knowledge"],
        "parameters": [{ "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Array of entities" }, "400": { "description": "Store has no graph entities" } }
