{
  "name": "agent-orcha",
  "version": "0.1.1",
  "description": "TypeScript Agentic Orchestration http server and framework for building multi-agent workflows with MCP tools and vector stores",
  "keywords": [
    "ai",
    "agents",
    "llm",
    "mcp",
    "vector-store",
    "rag",
    "orchestrator",
    "workflow",
    "typescript",
    "orca"
  ],
  "author": "David Dalcu <david.dalcu@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ddalcu/agent-orcha.git"
  },
  "homepage": "https://agentorcha.com",
  "type": "module",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "bin": {
    "agent-orcha": "bin/cli.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "NODE_ENV=development node --watch-path=src --watch-path=lib src/index.ts",
    "dev:p2p": "P2P_ENABLED=true NODE_ENV=development node --watch-path=src --watch-path=lib src/index.ts",
    "build:ui": "cd ui && npm ci && npm run build",
    "build": "npm run build:ui && tsc && npm run copy-assets",
    "copy-assets": "node -e \"const fs=require('fs');fs.cpSync('public','dist/public',{recursive:true});fs.cpSync('templates','dist/templates',{recursive:true,filter:(s)=>!s.split('/').some(p=>p.startsWith('.')&&p!=='.'&&p!=='.env.example')})\"",
    "start": "node dist/src/index.js",
    "prepublishOnly": "npm run build",
    "lint": "eslint src lib --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-test-module-mocks --test --test-force-exit 'test/**/*.test.ts'",
    "test:coverage": "node --experimental-test-module-mocks --test --test-force-exit --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=lcov.info --test-reporter=spec --test-reporter-destination=stdout 'test/**/*.test.ts'",
    "docker": "node scripts/detect-gpu.mjs --yes",
    "docker:gpu": "node scripts/detect-gpu.mjs",
    "docker:nvidia": "docker compose -f docker-compose.yaml -f docker-compose.nvidia.yaml up --build --watch",
    "docker:amd": "docker compose -f docker-compose.yaml -f docker-compose.amd.yaml up --build --watch",
    "build:binary": "node scripts/build-sea.mjs",
    "sea": "node scripts/build-sea.mjs && ./dist/sea/agent-orcha",
    "test:e2e": "npx playwright test",
    "prepare": "bash scripts/install-hooks.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.76.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.0.4",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.1.0",
    "glob": "^11.0.0",
    "hyperswarm": "^4.17.0",
    "imapflow": "^1.2.10",
    "jsdom": "^28.1.0",
    "mammoth": "^1.11.0",
    "mysql2": "^3.12.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "openai": "^6.22.0",
    "pdf-parse": "^1.1.4",
    "pg": "^8.13.2",
    "pino": "^10.2.1",
    "pino-pretty": "^13.1.3",
    "sqlite-vec": "^0.1.7-alpha.2",
    "ws": "^8.18.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.12",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
