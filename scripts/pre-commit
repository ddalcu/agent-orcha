#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

BYPASS_MSG="Use ${YELLOW}git commit --no-verify${NC} to bypass."

# ─── Check 1: Forbidden files ────────────────────────────────────────────────
FORBIDDEN_PATTERNS='\.env$|\.pem$|\.key$|\.p12$|\.pfx$|^credentials|/credentials'
FORBIDDEN_FILES=$(git diff --cached --name-only | grep -E "$FORBIDDEN_PATTERNS" || true)

if [ -n "$FORBIDDEN_FILES" ]; then
  echo -e "${RED}Blocked: commit contains sensitive files:${NC}"
  echo "$FORBIDDEN_FILES"
  echo -e "$BYPASS_MSG"
  exit 1
fi

# ─── Check 2: Secret patterns in staged diff ─────────────────────────────────
SECRET_PATTERNS='sk-[a-zA-Z0-9_-]{20,}|sk-ant-[a-zA-Z0-9_-]{20,}|AIza[a-zA-Z0-9_-]{30,}|ghp_[a-zA-Z0-9]{36}|gho_[a-zA-Z0-9]{36}|AKIA[A-Z0-9]{16}|xoxb-[a-zA-Z0-9-]+|xoxp-[a-zA-Z0-9-]+'

# Scan only added lines (starting with +), skip diff headers (+++), skip test fixtures
LEAKED=$(git diff --cached -U0 -- ':!test/' ':!*.test.ts' ':!*.spec.ts' \
  | grep '^+' \
  | grep -v '^+++' \
  | grep -E "$SECRET_PATTERNS" || true)

if [ -n "$LEAKED" ]; then
  echo -e "${RED}Blocked: possible secret/API key detected in staged changes:${NC}"
  echo "$LEAKED"
  echo -e ""
  echo -e "If this is a false positive, add the pattern to ${YELLOW}scripts/.secretsallow${NC}."
  echo -e "$BYPASS_MSG"
  exit 1
fi

# ─── Check 3: TypeScript type check ──────────────────────────────────────────
echo -e "${YELLOW}Running typecheck...${NC}"
if ! npx tsc --noEmit 2>&1; then
  echo -e "${RED}Blocked: TypeScript errors found.${NC}"
  echo -e "$BYPASS_MSG"
  exit 1
fi
echo -e "${GREEN}Typecheck passed.${NC}"

# ─── Check 4: Unit tests ─────────────────────────────────────────────────────
echo -e "${YELLOW}Running tests...${NC}"
if ! npm test 2>&1; then
  echo -e "${RED}Blocked: unit tests failed.${NC}"
  echo -e "$BYPASS_MSG"
  exit 1
fi
echo -e "${GREEN}Tests passed.${NC}"

# ─── All clear ────────────────────────────────────────────────────────────────
echo -e "${GREEN}All pre-commit checks passed.${NC}"
